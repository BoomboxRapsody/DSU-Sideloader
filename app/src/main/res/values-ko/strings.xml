    <!-- Allocation error card -->
    <string name="allocation_error">할당 오류</string>
    <string name="allocation_error_description">SD카드 할당이 작동하지 않습니다. 시도해 볼 수 있는 몇 가지 수정 사항이 있습니다:\n - DSU Sideloader의 Magisk 모듈을 설치하세요.\n - SD카드 마운트 해제(설정에서 이 옵션을 영구적으로 설정할 수 있습니다).</string>
    <string name="allocation_error_action">SD카드 마운트 해제하고 다시 시도</string>

    <!-- No free storage error card -->
    <string name="storage_error">저장소 오류</string>
    <string name="storage_error_description">Android는 설치를 진행하고 공간을 확보한 후 다시 시도하려면 최소 %1$s%의 여유 저장 공간이 필요합니다.</string>

    <!-- Filesystem features not found error card -->
    <string name="fs_features_error">FS 기능을 사용할 수 없음</string>
    <string name="fs_features_error_description">당신의 커널은 GSI 데몬에서 예상했던 다른 경로로 f2fs를 등록하고 있을 가능성이 큽니다. 시도해 볼 수 있는 몇 가지 수정 사항이 있습니다:\n - DSU Sideloader의 Magisk 모듈을 설치하세요.\n - 커널을 바꾸세요.</string>

    <!-- SELinux error card -->
    <string name="selinux_error">SELinux 오류</string>
    <string name="selinux_error_description">SELinux 부정이 DSU 설치를 방해하는 것 같습니다. 몇 가지 수정 사항이 있습니다:\n - DSU Sideloader의 Magisk 모듈을 설치하세요.\n - SD카드를 사용하는 경우 마운트 해제를 시도해 보세요(설정 섹션에 해당 옵션이 있습니다).\n - SELinux를 Permissive으로 변경하세요(권장하지 않으며 기기 보안이 약화됩니다).</string>
    <string name="selinux_error_action">Permissive으로 다시 시도</string>

    <!-- Extents error card -->
    <string name="extents_error_title">범위 오류</string>
    <string name="extents_error_description">Android 10 장치에서는 이미지/파일 시스템에 512개 이상의 익스텐트가 필요하며, 몇 가지 수정 사항을 시도해 볼 수 있습니다:\n - DSU Sideloader의 Magisk 모듈을 설치하세요.</string>

